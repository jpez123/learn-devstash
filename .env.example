# Neon PostgreSQL (dev branch)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

AUTH_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
RESEND_API_KEY=""

# Set to "false" to skip email verification (useful when no domain is linked in Resend)
# Defaults to "true" (verification enabled) if not set
EMAIL_VERIFICATION_ENABLED="true"

# Upstash Redis — used for auth rate limiting (optional, fails open if not set)
# Get credentials at https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_MONTHLY=""
STRIPE_PRICE_ID_YEARLY=""